{
  "name": "lazyslides",
  "version": "0.4.1",
  "description": "Slide decks with native agentic AI integration",
  "license": "MIT",
  "author": "Chris Tietz",
  "keywords": [
    "presentations",
    "slides",
    "reveal.js",
    "eleventy",
    "yaml",
    "tailwind",
    "ai",
    "claude",
    "slide-deck"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chrisissorry/lazyslides.git"
  },
  "homepage": "https://github.com/Chrisissorry/lazyslides",
  "bugs": {
    "url": "https://github.com/Chrisissorry/lazyslides/issues"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./styles.css": "./src/styles.css"
  },
  "bin": {
    "lazyslides": "./cli.js"
  },
  "files": [
    "index.js",
    "cli.js",
    "lib/",
    "_layouts/",
    "_includes/",
    "assets/",
    "src/",
    "scaffold/",
    "data/"
  ],
  "scripts": {
    "dev": "node cli.js validate && concurrently \"pnpm:watch:*\"",
    "watch:css": "pnpm exec tailwindcss -i src/styles.css -o _site/assets/css/styles.css --watch",
    "watch:11ty": "pnpm exec eleventy --serve",
    "build": "node cli.js validate && pnpm run build:css && pnpm run build:11ty",
    "build:css": "pnpm exec tailwindcss -i src/styles.css -o _site/assets/css/styles.css",
    "build:11ty": "pnpm exec eleventy",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "node cli.js validate",
    "renumber": "node cli.js renumber",
    "pdf": "node cli.js pdf"
  },
  "peerDependencies": {
    "@11ty/eleventy": "^3.0.0"
  },
  "dependencies": {
    "decktape": "^3.14.0",
    "js-yaml": "^4.1.0"
  },
  "optionalDependencies": {
    "@terrastruct/d2": "^0.1.33"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@tailwindcss/cli": "4.1.18",
    "concurrently": "^9.0.0",
    "tailwindcss": "4.3.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ],
    "overrides": {
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "basic-ftp@<=5.2.1": ">=5.2.2",
      "@xmldom/xmldom@<0.9.10": ">=0.9.10",
      "ip-address@<10.1.1": ">=10.1.1",
      "vite@>=7.0.0 <7.3.2": ">=7.3.2",
      "liquidjs@<=10.25.2": ">=10.25.3"
    }
  }
}
